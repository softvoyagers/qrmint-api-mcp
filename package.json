  "description": "MCP server for QRMint (qrmint.dev) — generate styled QR codes from Claude, Cursor, and any MCP-compatible AI assistant. No API key required.",
  "main": "dist/index.js",
  "bin": {
    "qrmint-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "qrmint",
    "qr-code",
    "ai",
    "claude",
    "softvoyagers"
  ],
  "license": "MIT",
  "author": "SoftVoyagers",
  "repository": {
    "type": "git",
    "url": "https://github.com/softvoyagers/qrmint-api-mcp"
  },
  "homepage": "https://qrmint.dev",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "typescript": "^5.9.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
